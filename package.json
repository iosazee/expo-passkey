{
  "name": "expo-passkey",
  "version": "0.1.0-alpha.16",
  "type": "module",
  "description": "Passkey authentication for Expo apps with Better Auth integration",
  "author": "Zee Mudia",
  "license": "MIT",
  "keywords": [
    "expo",
    "passkey",
    "biometric",
    "authentication",
    "better-auth",
    "react-native",
    "face-id",
    "touch-id",
    "fingerprint"
  ],
  "homepage": "https://github.com/iosazee/expo-passkey",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iosazee/expo-passkey.git"
  },
  "bugs": {
    "url": "https://github.com/iosazee/expo-passkey/issues"
  },
  "main": "build/index.js",
  "module": "build/index.js",
  "types": "build/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "expo": {
    "name": "expo-passkey",
    "platforms": [
      "ios",
      "android"
    ]
  },
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/cjs/index.cjs"
    },
    "./client": {
      "types": "./build/client/index.d.ts",
      "import": "./build/client/index.js",
      "require": "./build/cjs/client/index.cjs"
    },
    "./server": {
      "types": "./build/server/index.d.ts",
      "import": "./build/server/index.js",
      "require": "./build/cjs/server/index.cjs"
    },
    "./types": {
      "types": "./build/types/index.d.ts",
      "import": "./build/types/index.js",
      "require": "./build/cjs/types/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./build/client/index.d.ts"
      ],
      "server": [
        "./build/server/index.d.ts"
      ],
      "types": [
        "./build/types/index.d.ts"
      ]
    }
  },
  "files": [
    "build",
    "android",
    "ios",
    "LICENSE",
    "README.md",
    "scripts/check-server-deps.cjs",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf build",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "expo-module prepare",
    "prebuild:native": "expo-module build",
    "build:all": "npm run prebuild:native && npm run build",
    "expo-module": "expo-module",
    "postinstall": "node scripts/check-server-deps.cjs || true",
    "test": "jest",
    "test:client": "jest --selectProjects client",
    "test:server": "jest --selectProjects server",
    "test:watch": "jest --watch",
    "test:client:watch": "jest --selectProjects client --watch",
    "test:server:watch": "jest --selectProjects server --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "expo-module prepublishOnly && npm run test && npm run lint:fix && npm run build:all"
  },
  "devDependencies": {
    "@better-fetch/fetch": "^1.1.17",
    "@changesets/cli": "^2.28.1",
    "@eslint/js": "^9.23.0",
    "@jest/globals": "^29.7.0",
    "@simplewebauthn/types": ">=12.0.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.11",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "better-auth": "^1.2.4",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.4",
    "expo": "^52.0.40",
    "expo-application": "^6.0.2",
    "expo-crypto": "^14.0.2",
    "expo-device": "^7.0.2",
    "expo-local-authentication": "^15.0.2",
    "expo-module-scripts": "^4.0.5",
    "expo-secure-store": "^14.0.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.6",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@better-auth/expo": ">=1.0.0",
    "@better-fetch/fetch": ">=1.0.0",
    "@simplewebauthn/server": ">=13.0.0",
    "better-auth": ">=1.0.0",
    "expo": ">=50.0.0",
    "expo-application": ">=5.0.0",
    "expo-crypto": ">=12.0.0",
    "expo-device": ">=5.0.0",
    "expo-local-authentication": ">=13.0.0",
    "expo-modules-core": ">=2.2.3",
    "expo-secure-store": ">=12.0.0",
    "react-native": "*",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    },
    "expo-application": {
      "optional": true
    },
    "expo-local-authentication": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-crypto": {
      "optional": true
    },
    "expo-device": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "@better-auth/expo": {
      "optional": true
    },
    "expo-modules-core": {
      "optional": true
    },
    "@simplewebauthn/server": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
